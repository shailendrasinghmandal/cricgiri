# Production environment — copy to .env on server
HOST=0.0.0.0
PORT=8000
DEBUG=false
PUBLIC_BASE_URL=https://api.yourdomain.com

MODEL_VERSION=ball_best_v1
BALL_MODEL_PATH=models/ball_best.pt
STUMP_MODEL_PATH=models/stump_best.pt
DEVICE=
USE_HALF_PRECISION=false
INFERENCE_IMGSZ=640
BALL_CONFIDENCE=0.10
BOWLER_ARM=right
SAVE_ANNOTATED_VIDEO=true
BLUR_RECOVERY=false
MAX_UPLOAD_MB=200

# Optional security — clients send header: X-API-Key: your-secret
# API_KEY=change-me-in-production
